{
  "name": "ychang-sound",
  "displayName": "YChang Sound",
  "description": "6",
  "version": "1.0.9",
  "publisher": "Rickyeeeeee",
  "icon": "assets/cgv.jpg",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rickyeeeeee/YChang-Sound.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "YChang Sound",
      "properties": {
        "ychang-sound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the error sound on terminal command failure."
        },
        "ychang-sound.soundFile": {
          "type": "string",
          "enum": [
            "error.mp3"
          ],
          "enumItemLabels": [
            "Faah Sound"
          ],
          "default": "error.mp3",
          "description": "Select the sound clip to play on terminal command failure."
        },
        "ychang-sound.volume": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "description": "Volume of the error sound (0.0 to 1.0). Note: volume control depends on the system audio player."
        }
      }
    },
    "commands": [
      {
        "command": "ychang-sound.testSound",
        "title": "YChang Sound: Test Sound"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/vscode": "^1.93.0",
    "typescript": "^5.7.3"
  }
}